title: "Kirill's Writing"
url: "https://k-reel.github.io"
baseurl: ""
markdown: kramdown
permalink: /:year/:month/:day/:title/

# Build settings
theme: minima
plugins:
  - jekyll-feed
  - jekyll-seo-tag

# Social
github_username: K-reel

# Exclude
exclude:
  - Gemfile
  - Gemfile.lock
  - README.md
